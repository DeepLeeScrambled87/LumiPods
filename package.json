{
  "name": "lumipods",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:openai": "node --env-file=.env server/dev-with-openai.mjs",
    "ai-proxy": "node --env-file=.env server/openai-proxy.mjs",
    "openai:health": "node server/check-openai-health.mjs",
    "appwrite:preflight": "node --env-file=.env scripts/appwrite-preflight.mjs",
    "appwrite:migrate:dry": "node --env-file=.env scripts/migrate-pocketbase-to-appwrite.mjs --dry-run",
    "appwrite:migrate": "node --env-file=.env scripts/migrate-pocketbase-to-appwrite.mjs --apply",
    "appwrite:artifacts:diagnose": "node --env-file=.env scripts/appwrite-artifact-diagnostics.mjs",
    "appwrite:artifacts:retry": "node --env-file=.env scripts/appwrite-retry-failed-artifacts.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --host",
    "docker:build": "docker build -t lumipods:latest .",
    "docker:run": "docker run -p 8888:80 --name lumipods-app lumipods:latest",
    "docker:stop": "docker rm -f lumipods-app",
    "docker:up": "docker-compose up -d lumipods",
    "docker:down": "docker-compose down",
    "docker:dev": "docker-compose --profile dev up lumipods-dev"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.542.0",
    "pocketbase": "^0.26.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  }
}
